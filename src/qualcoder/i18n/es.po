# El texto simple debe coincidir exactamente para que Code PDF funcione correctamente.
#: src/qualcoder/code_pdf.py:285
msgid "Plain text must match exactly for Code PDF to work correctly."
msgstr ""
"El texto sin formato debe coincidir exactamente para que Code PDF funcione "
"correctamente."

# Aparecerá una advertencia si el texto del PDF analizado no coincide con el texto simple almacenado en la base de datos
#: src/qualcoder/code_pdf.py:286
msgid ""
"A warning will display if the parsed PDF text does not match the database "
"stored plain text."
msgstr ""
"Aparecerá una advertencia si el texto del PDF analizado no coincide con el "
"texto sin formato almacenado en la base de datos."

# El texto simple de los PDFs cargados en QualCoder antes de la versión 3.4 no tendrá las posiciones de texto simple correctas para la visualización de PDF.
#: src/qualcoder/code_pdf.py:288
msgid ""
"Plain text of PDFs loaded in to QualCoder before version 3.4 will not have "
"the plain text positions correct for PDF display."
msgstr ""
"El texto sin formato de los PDF cargados en QualCoder antes de la versión "
"3.4 no tendrá las posiciones de texto sin formato correctas para la "
"visualización de PDF."

#: src/qualcoder/code_pdf.py:289
msgid "This means coding stripes will show in incorrect positions."
msgstr ""
"Esto significa que las rayas de codificación se mostrarán en posiciones "
"incorrectas."

# Texto simple
#: src/qualcoder/code_pdf.py:291
msgid ""
"Similarly, if the PDF plain text has been edited in any way, this will "
"affect coding stripes display."
msgstr ""
"Del mismo modo, si el texto sin formato del PDF ha sido editado de algún "
"modo, esto afectará a la visualización de las bandas de codificación."

