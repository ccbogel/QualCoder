#: src/qualcoder/view_graph_relations.py:337
msgid "Connection without a named relation type."
msgstr "Connexion sans type de relation nommé."

#: src/qualcoder/view_graph_relations.py:338
msgid ""
"Two concepts co-occur or are linked but without a specified causal or "
"hierarchical direction."
msgstr ""
"Deux concepts coexistent ou sont liés mais sans une direction causale ou "
"hiérarchique spécifiée."

#: src/qualcoder/view_graph_relations.py:339
msgid "One concept produces, generates, or leads to another."
msgstr "Un concept produit, génère ou conduit à un autre."

#: src/qualcoder/view_graph_relations.py:340
msgid "One concept is a component, dimension, or facet of another."
msgstr ""
"Un concept est une composante, une dimension ou une facette d'un autre."

#: src/qualcoder/view_graph_relations.py:341
msgid "Subsumption: one concept is a type or instance of another."
msgstr "Subsomption : un concept est un type ou une instance d'un autre."

#: src/qualcoder/view_graph_relations.py:342
msgid "One concept describes an attribute or quality of another."
msgstr "Un concept décrit un attribut ou une qualité d'un autre."

#: src/qualcoder/view_graph_relations.py:343
msgid "Two concepts are in tension, opposition, or mutual exclusion."
msgstr "Deux concepts sont en tension, opposition ou exclusion mutuelle."

#: src/qualcoder/view_graph_relations.py:344
msgid ""
"One concept provides evidence, confirmation, or reinforcement for another."
msgstr ""
"Un concept fournit des preuves, une confirmation ou un renforcement pour un "
"autre."

#: src/qualcoder/view_graph_relations.py:345
msgid "One concept provides the situational backdrop for another."
msgstr "Un concept fournit le contexte situationnel pour un autre."

#: src/qualcoder/view_graph_relations.py:346
msgid "One concept occurs before another in time or sequence."
msgstr "Un concept se produit avant un autre dans le temps ou la séquence."

#: src/qualcoder/view_graph_relations.py:347
msgid "One concept provides the rationale or legitimation for another."
msgstr "Un concept fournit la justification ou la légitimité d'un autre."

#: src/qualcoder/view_graph_relations.py:348
msgid ""
"A causal, intervening, or contextual condition that influences the "
"phenomenon."
msgstr ""
"Une condition causale, intermédiaire ou contextuelle qui influence le "
"phénomène."

#: src/qualcoder/view_graph_relations.py:349
msgid ""
"An action/interaction strategy used in response to or to manage the "
"phenomenon."
msgstr ""
"Une stratégie d'action/d'interaction utilisée en réponse ou pour gérer le "
"phénomène."

#: src/qualcoder/view_graph_relations.py:350
msgid "A result or outcome that follows from action/interaction strategies."
msgstr "Résultat ou résultat découlant des stratégies d'action/d'interaction."

#: src/qualcoder/view_graph_relations.py:351
msgid "The set of conditions within which strategies are enacted."
msgstr ""
"L'ensemble des conditions dans lesquelles les stratégies sont adoptées."

#: src/qualcoder/view_graph_relations.py:352
msgid ""
"A broader structural condition that facilitates or constrains strategies."
msgstr ""
"Une condition structurelle plus large qui facilite ou limite les stratégies."

#: src/qualcoder/view_graph_relations.py:353
msgid "The core category or central idea to which all other categories relate."
msgstr ""
"La catégorie centrale ou l'idée centrale à laquelle se rapportent toutes les "
"autres catégories."

#: src/qualcoder/view_graph_relations.py:354
msgid "A property varies along this continuum or range."
msgstr "Une propriété varie le long de ce continuum ou de cette plage."

#: src/qualcoder/view_graph_relations.py:355
msgid "One category is subsumed under or elaborates a higher-order category."
msgstr ""
"Une catégorie est englobée par une catégorie d'ordre supérieur ou en "
"constitue un développement."

#: src/qualcoder/view_graph_relations.py:356
msgid "Two concepts co-occur without specified directionality."
msgstr "Deux concepts coexistent sans directionnalité spécifiée."

#: src/qualcoder/view_graph_relations.py:357
msgid "A processual or temporal link between phases."
msgstr "Un lien processuel ou temporel entre les phases."

#: src/qualcoder/view_graph_relations.py:358
msgid "A superordinate category that organizes subcategories."
msgstr "Une catégorie de niveau supérieur qui organise des sous-catégories."

#: src/qualcoder/view_graph_relations.py:359
msgid "A subordinate category under a main category."
msgstr "Une catégorie subordonnée à une catégorie principale."

#: src/qualcoder/view_graph_relations.py:360
msgid "A prototypical text passage that defines a category."
msgstr "Un passage textuel prototypique qui définit une catégorie."

#: src/qualcoder/view_graph_relations.py:361
msgid "A decision rule that resolves ambiguity between categories."
msgstr "Une règle de décision qui lève l'ambiguïté entre les catégories."

#: src/qualcoder/view_graph_relations.py:362
msgid "Two categories share some coded segments or meaning."
msgstr ""
"Deux catégories partagent certains segments codés ou une certaine "
"signification."

#: src/qualcoder/view_graph_relations.py:363
msgid "One category is a more precise version of another after revision."
msgstr "Une catégorie est une version plus précise d'une autre après révision."

#: src/qualcoder/view_graph_relations.py:364
msgid "Two categories or findings are in tension."
msgstr "Deux catégories ou résultats sont en tension."

#: src/qualcoder/view_graph_relations.py:365
msgid "One category captures the gist of several lower-level categories."
msgstr ""
"Une catégorie saisit l'essentiel de plusieurs catégories de niveau inférieur."

#: src/qualcoder/view_graph_relations.py:366
msgid "One category clarifies the meaning of another through context."
msgstr "Une catégorie clarifie le sens d'une autre dans le contexte."

#: src/qualcoder/view_graph_relations.py:367
msgid "One category provides the organizing frame for others."
msgstr "Une catégorie fournit le cadre organisateur pour les autres."

#: src/qualcoder/view_graph_relations.py:368
msgid "Describes WHAT was experienced (the noema)."
msgstr "Décrit ce qui a été vécu (le noème)."

#: src/qualcoder/view_graph_relations.py:369
msgid "Describes HOW the experience was lived (the noesis)."
msgstr "Décrit COMMENT l'expérience a été vécue (la noèse)."

#: src/qualcoder/view_graph_relations.py:370
msgid "The invariant meaning that persists across individual experiences."
msgstr ""
"La signification invariable qui persiste à travers les expériences "
"individuelles."

#: src/qualcoder/view_graph_relations.py:371
msgid "A meaning unit that bounds or delimits the experience."
msgstr "Une unité de sens qui borne ou délimite l'expérience."

#: src/qualcoder/view_graph_relations.py:372
msgid "An experiential structure that recurs across participants."
msgstr "Une unité de sens qui borne ou délimite l'expérience."

#: src/qualcoder/view_graph_relations.py:373
msgid ""
"The experience manifests through bodily sensation or corporeal presence."
msgstr ""
"L'expérience se manifeste par la sensation corporelle ou la présence du "
"corps."

#: src/qualcoder/view_graph_relations.py:374
msgid "The experience occurs within a specific spatial context."
msgstr "L'expérience se déroule dans un contexte spatial spécifique."

#: src/qualcoder/view_graph_relations.py:375
msgid "The experience unfolds within subjective time."
msgstr "L'expérience se déploie dans le temps subjectif."

#: src/qualcoder/view_graph_relations.py:376
msgid "The experience involves connection with others."
msgstr "L'expérience implique une connexion avec les autres."

#: src/qualcoder/view_graph_relations.py:377
msgid "One meaning unit participates in constructing a broader theme."
msgstr "Une unité de sens participe à la construction d'un thème plus large."

#: src/qualcoder/view_graph_relations.py:378
msgid "A data-driven or theory-driven label assigned to a data segment."
msgstr ""
"Une étiquette, fondée sur les données ou sur la théorie, attribuée à un "
"segment de données."

#: src/qualcoder/view_graph_relations.py:379
msgid "A provisional theme that groups related codes."
msgstr "Un thème provisoire qui regroupe des codes apparentés."

#: src/qualcoder/view_graph_relations.py:380
msgid "A theme nested within a broader overarching theme."
msgstr "Un thème imbriqué dans un thème plus vaste et englobant."

#: src/qualcoder/view_graph_relations.py:381
msgid "Two themes share codes or meaning territory."
msgstr "Deux thèmes partagent des codes ou un champ sémantique."

#: src/qualcoder/view_graph_relations.py:382
msgid "A revised version of a theme after review."
msgstr "Une version révisée d'un thème après examen."

#: src/qualcoder/view_graph_relations.py:383
msgid "The 'essence' or core meaning of a theme."
msgstr "L'« essence » ou la signification fondamentale d'un thème."

#: src/qualcoder/view_graph_relations.py:384
msgid "A vivid data extract that captures the theme."
msgstr "Un extrait de données saisissant qui reflète le thème."

#: src/qualcoder/view_graph_relations.py:385
msgid "One theme provides the situational backdrop for another."
msgstr "Un thème fournit la toile de fond situationnelle d'un autre."

#: src/qualcoder/view_graph_relations.py:386
msgid "Two themes or codes are in tension."
msgstr "Deux thèmes ou codes sont en tension."

#: src/qualcoder/view_graph_relations.py:387
msgid "Co-occurrence or conceptual affinity."
msgstr "Co-occurrence ou affinité conceptuelle."

#: src/qualcoder/view_graph_relations.py:388
msgid ""
"A discursive practice that produces a social object or subject position."
msgstr ""
"Une pratique discursive qui produit un objet social ou une position de sujet."

#: src/qualcoder/view_graph_relations.py:389
msgid "One discourse provides justification or authority to another."
msgstr "Un discours confère une justification ou une autorité à un autre."

#: src/qualcoder/view_graph_relations.py:390
msgid "A counter-discourse that challenges or subverts a dominant discourse."
msgstr ""
"Un contre-discours qui remet en question ou subvertit un discours dominant."

#: src/qualcoder/view_graph_relations.py:391
msgid "A discourse that makes a social construction appear self-evident."
msgstr ""
"Un discours qui fait apparaître une construction sociale comme allant de soi."

#: src/qualcoder/view_graph_relations.py:392
msgid "One text draws on, references, or transforms another text."
msgstr ""
"Un texte s'inspire d'un autre texte, y fait référence ou le transforme."

#: src/qualcoder/view_graph_relations.py:393
msgid "The discourse assigns an identity or role to social actors."
msgstr "Le discours attribue une identité ou un rôle aux acteurs sociaux."

#: src/qualcoder/view_graph_relations.py:394
msgid "The linguistic variety associated with a social context."
msgstr "La variété linguistique associée à un contexte social."

#: src/qualcoder/view_graph_relations.py:395
msgid "The degree of certainty, obligation, or commitment expressed."
msgstr "Le degré de certitude, d'obligation ou d'engagement exprimé."

#: src/qualcoder/view_graph_relations.py:396
msgid "One statement takes another as given or assumed."
msgstr "Une affirmation en prend une autre pour acquise ou comme postulat."

#: src/qualcoder/view_graph_relations.py:397
msgid "One concept is understood through the frame of another."
msgstr "Un concept est appréhendé à travers le prisme d'un autre."

#: src/qualcoder/view_graph_relations.py:400
msgid "Use for simple visual links between codes."
msgstr "À utiliser pour des liens visuels simples entre les codes."

#: src/qualcoder/view_graph_relations.py:401
msgid "Symmetric relation. Most common default."
msgstr "Relation symétrique. Par défault le plus courant."

#: src/qualcoder/view_graph_relations.py:402
msgid "Asymmetric: A causes B ≠ B causes A."
msgstr "Asymétrique : A cause B ≠ B cause A."

#: src/qualcoder/view_graph_relations.py:403
msgid "Mereological relation (part-whole)."
msgstr "Relation méréologique (partie-tout)."

#: src/qualcoder/view_graph_relations.py:404
msgid "Taxonomic / ISA hierarchy."
msgstr "Hiérarchie taxonomique / ISA."

#: src/qualcoder/view_graph_relations.py:405
msgid "Property-bearer relation."
msgstr "Relation porteur-propriété."

#: src/qualcoder/view_graph_relations.py:406
msgid "Useful for mapping analytical tensions."
msgstr "Utile pour cartographier les tensions analytiques."

#: src/qualcoder/view_graph_relations.py:407
msgid "Evidential or corroborative link."
msgstr "Lien probant ou corroboratif."

#: src/qualcoder/view_graph_relations.py:408
msgid "Contextual framing relation."
msgstr "Relation de cadrage contextuel."

#: src/qualcoder/view_graph_relations.py:409
msgid "Temporal or processual ordering."
msgstr "Temporal or processual ordering.Ordre temporel ou processuel."

#: src/qualcoder/view_graph_relations.py:410
msgid "Argumentative or normative link."
msgstr "Lien argumentatif ou normatif."

#: src/qualcoder/view_graph_relations.py:411
msgid "Axial coding: conditions → phenomenon."
msgstr "Codage axial : conditions → phénomène."

#: src/qualcoder/view_graph_relations.py:412
msgid "Axial coding: phenomenon → strategies."
msgstr "Codage axial : phénomène → stratégies."

#: src/qualcoder/view_graph_relations.py:413
msgid "Axial coding: strategies → consequences."
msgstr "Codage axial : stratégies → conséquences."

#: src/qualcoder/view_graph_relations.py:414
msgid "Narrow situational conditions."
msgstr "Conditions situationnelles restreintes."

#: src/qualcoder/view_graph_relations.py:415
msgid "Intervening conditions in paradigm model."
msgstr "Conditions intermédiaires dans le modèle paradigmatique."

#: src/qualcoder/view_graph_relations.py:416
msgid "Identified during selective coding."
msgstr "Identifié lors du codage sélectif."

#: src/qualcoder/view_graph_relations.py:417
msgid "Properties and dimensions of categories."
msgstr "Propriétés et dimensions des catégories."

#: src/qualcoder/view_graph_relations.py:418
msgid "Hierarchical abstraction."
